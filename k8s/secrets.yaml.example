---
# k8s/secrets.yaml.example
#
# Copy this file to k8s/secrets.yaml and fill in every <placeholder> before
# running `kubectl apply -f k8s/secrets.yaml`.
#
# secrets.yaml is gitignored — never commit real values.
#
# Namespace: update every `namespace:` field to match your cluster namespace.
#
# Key generation helpers:
#   openssl rand -hex 32          # 256-bit hex key (SpiceDB preshared, MCP API key)
#   openssl rand -base64 32       # 256-bit base64 key (general bearer tokens)
#

---
# SpiceDB preshared key — used by all SpiceDB clients (agents, connectors, CLI).
# Must match the --grpc-preshared-key value SpiceDB was started with.
apiVersion: v1
kind: Secret
metadata:
  name: spicedb-preshared-key
  namespace: <your-namespace>
  labels:
    app.kubernetes.io/name: spicedb
    app.kubernetes.io/component: auth
    app.kubernetes.io/part-of: notflux-registry
type: Opaque
stringData:
  # Generate: openssl rand -hex 32
  presharedKey: "<spicedb-preshared-key>"
  # Bearer token presented by remote agents to the SpiceDB MCP bridge.
  # Generate: openssl rand -hex 32
  mcpApiKey: "<mcp-bridge-api-key>"

---
# registry-agent-secrets
# Injected into the registry-agent (Google ADK / ag_ui_adk) pod.
# Create/update via: kubectl apply -f k8s/secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: registry-agent-secrets
  namespace: <your-namespace>
  labels:
    app.kubernetes.io/name: registry-agent
    app.kubernetes.io/component: agent
    app.kubernetes.io/part-of: notflux-registry
type: Opaque
stringData:
  # Gemini API key — google-genai direct (not Vertex AI).
  # https://aistudio.google.com/apikey
  GOOGLE_API_KEY: "<gemini-api-key>"

  # SpiceDB MCP bridge URL, routed through PingGateway.
  # Example: https://<your-gateway-host>/mcp/agent-registry
  MCP_BRIDGE_URL: "https://<your-gateway-host>/mcp/agent-registry"

  # Weather MCP server URL (same PingGateway, same per-turn token).
  # Example: https://<your-gateway-host>/mcp/weather
  WEATHER_MCP_URL: "https://<your-gateway-host>/mcp/weather"

  # PingOne token exchange — confidential client used by the agent to exchange
  # the incoming agent_token for a gateway-scoped mcp_token (RFC 8693).
  # This is a DIFFERENT client from the frontend's OIDC client.
  # Required grants: Token Exchange (urn:ietf:params:oauth:grant-type:token-exchange)
  PINGONE_ENV_ID: "<pingone-environment-id>"
  PINGONE_CLIENT_ID: "<agent-token-exchange-client-id>"
  # Confidential client secret — authenticates the client in the token exchange call.
  # The projected SA token (PINGONE_SA_TOKEN_PATH) is used as actor_token in the same
  # RFC 8693 exchange, proving which k8s workload is acting. Both are required.
  PINGONE_CLIENT_SECRET: "<agent-token-exchange-client-secret>"

  # Expected `aud` claim in the incoming agent_token (set when frontend exchanges).
  PINGONE_AGENT_AUDIENCE: "registry-agent"

  # Scope to request in the outbound token exchange.
  # PingOne maps this scope to the MCP/gateway resource server `aud`.
  PINGONE_MCP_SCOPE: "<gateway-scope>"

  # DaVinci policy flow for token exchange (actor_token + subject_token → mcp_token).
  # URL format: https://orchestrate-api.pingone.com/v1/company/<env-id>/policy/<flow-id>/start
  DAVINCI_POLICY_URL: "https://orchestrate-api.pingone.com/v1/company/<pingone-environment-id>/policy/<davinci-flow-id>/start"
  # API key shown in the DaVinci flow's API Access settings.
  DAVINCI_POLICY_API_KEY: "<davinci-flow-api-key>"

  # Registry-PIP MCP endpoint + static bearer token.
  # Get the deployed key: kubectl get secret registry-pip-secrets -n <your-namespace> \
  #   -o jsonpath='{.data.MCP_API_KEY}' | base64 -d
  REGISTRY_PIP_URL: "https://<registry-pip-host>/mcp"
  REGISTRY_PIP_API_KEY: "<registry-pip-mcp-api-key>"

---
# registry-frontend-secrets
# Injected into the registry-frontend (Next.js) pod.
# Create/update via: kubectl apply -f k8s/secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: registry-frontend-secrets
  namespace: <your-namespace>
  labels:
    app.kubernetes.io/name: registry-frontend
    app.kubernetes.io/component: frontend
    app.kubernetes.io/part-of: notflux-registry
type: Opaque
stringData:
  # In-cluster ag_ui_adk AG-UI endpoint.
  # Example: http://registry-agent.<your-namespace>.svc.cluster.local:8000
  AGENT_ENGINE_URL: "http://registry-agent.<your-namespace>.svc.cluster.local:8000"

  # Gemini API key for CopilotKit's GoogleGenerativeAIAdapter (server-side).
  GOOGLE_GENERATIVE_AI_API_KEY: "<gemini-api-key>"

  # PingOne OIDC — confidential client for the frontend authorization_code flow.
  # Required grants: Authorization Code + PKCE, Token Exchange
  # Redirect URI: https://<your-frontend-host>/api/auth/callback
  PINGONE_ENV_ID: "<pingone-environment-id>"
  PINGONE_CLIENT_ID_FRONTEND: "<frontend-oidc-confidential-client-id>"
  PINGONE_CLIENT_SECRET_FRONTEND: "<frontend-oidc-confidential-client-secret>"

  # Scope requested at login — access_token should carry aud=registry-agent.
  PINGONE_AGENT_SCOPE: "registry-agent"

  # Public values baked into the browser bundle for the /as/authorize redirect.
  # NEXT_PUBLIC_ values are visible to the browser — client IDs are fine, never put secrets here.
  NEXT_PUBLIC_PINGONE_ENV_ID: "<pingone-environment-id>"
  # Public SPA / PKCE client (no client secret).
  NEXT_PUBLIC_PINGONE_CLIENT_ID: "<frontend-pkce-public-client-id>"
